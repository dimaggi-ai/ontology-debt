# Copy this file to `.env` (which is gitignored) and paste your real keys.
# The `ontodebt run` command loads `.env` automatically. Never commit `.env`.

# Anthropic — console.anthropic.com → API keys (needs prepaid credits)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — platform.openai.com → API keys (needs a payment method/credits)
OPENAI_API_KEY=sk-...

# Only for publishing to PyPI (not read by the tool). pypi.org → API tokens.
# PYPI_TOKEN=pypi-...
